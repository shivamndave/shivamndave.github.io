{
  "name": "shivamndave.github.io",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://shivamndave.github.io/shivamndave.github.io/",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "check": "npm run lint && npm run type-check && npm run format",
    "lint": "eslint .",
    "format": "prettier --write src/**/*.{ts,tsx}",
    "type-check": "tsc --noEmit",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.4",
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/vite": "^4.1.11",
